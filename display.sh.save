# Funktion: display_dashboard
# Zweck: Rendert das komplette Dashboard
function display_dashboard() {
    clear # Terminal leeren für saubere Anzeige
    echo -e "${COLOR_BOLD}=== SafeSync Enterprise Monitor ===${COLOR_RESET}\n"

    draw_table_header

    # Hier kommt später eine Schleife hin, die alle Währungen durchgeht.
    # Für das Layout-Testing hier ein Hardcoded-Beispiel mit printf:

    # Beispiel: EUR Daten
    local trend_sym=$(get_trend_symbol 0.95 0.94)
    local trend_col=$(get_trend_color 0.95 0.94)et_trend_color 0.95 0.94)
    local bar=$(draw_progress_bar 80)

    # Formatierte Ausgabe der Tabellenzeile
    printf "║ %-8s ║ %-12s ║ ${trend_col}%-9s${COLOR_RESET} ║ %-20s ║\n" "EUR" "0.95 CHF" "$trend_sym" "$bar"

    draw_table_footer
}
# Test-Aufruf, um das Dashboard anzuzeigen
display_dashboard
# Funktion: display_dashboard
# Zweck: Rendert das komplette Dashboard
function display_dashboard() {
    clear # Terminal leeren für saubere Anzeige
    echo -e "${COLOR_BOLD}=== SafeSync Enterprise Monitor ===${COLOR_RESET}\n"

    draw_table_header

    # Beispiel: EUR Daten
    local trend_sym=$(get_trend_symbol 0.95 0.94)
    local trend_col=$(get_trend_color 0.95 0.94)
    local bar=$(draw_progress_bar 80)

    # LÖSUNG: Wir nutzen %s (ohne Längenangabe) für Unicode und tippen die 
    # exakt benötigten Leerzeichen für die 11 bzw. 22 Zeichen breiten Spalten von Hand.
    printf "║ %-8s ║ %-12s ║ ${trend_col}%s${COLOR_RESET}         ║ %s         ║\n" "EUR" "0.95 CHF" "$trend_sym" "$bar"

    draw_table_footer
}
